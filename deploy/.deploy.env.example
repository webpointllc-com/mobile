# Mobile Lane — gitignored local secrets (copy to deploy/.deploy.env; NEVER commit)
# Option A (per-service): deploy hook from Render -> service -> Settings -> Deploy Hook
RENDER_DEPLOY_HOOK_URL=
# Option B (account-wide; enables zero-click NEW service creation via API):
RENDER_API_KEY=
RENDER_SERVICE_ID=
MOBILE_URL=https://webpoint-mobile.onrender.com
